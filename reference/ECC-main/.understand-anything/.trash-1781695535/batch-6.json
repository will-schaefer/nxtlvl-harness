      "id": "file:src/llm/core/interface.py",
      "type": "file",
      "name": "interface.py",
      "filePath": "src/llm/core/interface.py",
      "summary": "Defines the abstract `LLMProvider` base class and the full error hierarchy (`LLMError`, `AuthenticationError`, `RateLimitError`, `ContextLengthError`, `ModelNotFoundError`, `ToolExecutionError`) that all provider implementations must implement and raise.",
      "tags": ["type-definition", "service", "api-handler"],
      "complexity": "simple",
      "languageNotes": "Uses Python ABC protocol with abstract methods; error hierarchy is single-inheritance from LLMError which itself extends Exception."
    },
