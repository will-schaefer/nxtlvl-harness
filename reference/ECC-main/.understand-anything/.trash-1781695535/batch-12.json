      "name": "sumUsageFromTranscript",
      "filePath": "scripts/hooks/cost-tracker.js",
      "lineRange": [96, 129],
      "summary": "Parses a Claude session transcript file line-by-line (JSONL), accumulating input/output/cache token counts and total cost across all usage events.",
      "tags": ["cost-tracking", "parsing", "utility"],
      "complexity": "moderate"
    },
    {
      "id": "function:scripts/hooks/cost-tracker.js:readHarnessCost",
      "type": "function",
      "name": "readHarnessCost",
      "filePath": "scripts/hooks/cost-tracker.js",
      "lineRange": [54, 69],
      "summary": "Reads a harness-managed cost cache file from the OS temp directory for a given session, returning cost data only when within the allowed max-age window.",
      "tags": ["cost-tracking", "file-io", "caching"],
      "complexity": "simple"
    },
    {
      "id": "file:scripts/hooks/ecc-context-monitor.js",
      "type": "file",
      "name": "ecc-context-monitor.js",
      "filePath": "scripts/hooks/ecc-context-monitor.js",
      "summary": "PostToolUse hook that monitors Claude Code session health by evaluating context window usage, cost thresholds, idle time, scope drift, and tool-call loops, emitting structured warnings to be surfaced to the user.",
      "tags": ["hook", "monitoring", "event-handler", "context-awareness"],
      "complexity": "complex"
    },
    {
      "id": "function:scripts/hooks/ecc-context-monitor.js:evaluateConditions",
      "type": "function",
      "name": "evaluateConditions",
      "filePath": "scripts/hooks/ecc-context-monitor.js",
      "lineRange": [116, 185],
      "summary": "Inspects the session bridge data for a suite of warning conditions (high context, cost thresholds, idle time, scope drift, tool loops), returning an array of warning objects sorted by severity.",
      "tags": ["monitoring", "validation", "event-handler"],
      "complexity": "complex"
    },
    {
      "id": "function:scripts/hooks/ecc-context-monitor.js:run",
      "type": "function",
      "name": "run",
      "filePath": "scripts/hooks/ecc-context-monitor.js",
      "lineRange": [200, 271],
      "summary": "Main hook entry point that reads stdin JSON, loads bridge data, evaluates session conditions, and writes structured output (or empty pass-through) based on active warnings and suppress state.",
      "tags": ["hook", "entry-point", "event-handler"],
      "complexity": "complex"
    },
    {
      "id": "file:scripts/hooks/ecc-metrics-bridge.js",
      "type": "file",
      "name": "ecc-metrics-bridge.js",
      "filePath": "scripts/hooks/ecc-metrics-bridge.js",
      "summary": "PostToolUse hook that accumulates per-session metrics (token counts, cost, recently edited files, hashed tool calls) into a shared session bridge file, enabling other hooks and the statusline to display live stats.",
      "tags": ["hook", "metrics", "event-handler", "monitoring"],
      "complexity": "complex"
    },
    {
      "id": "function:scripts/hooks/ecc-metrics-bridge.js:hashToolCall",
      "type": "function",
      "name": "hashToolCall",
      "filePath": "scripts/hooks/ecc-metrics-bridge.js",
      "lineRange": [46, 78],
      "summary": "Produces a stable 8-character SHA-256 hash for a tool call, using content-aware fingerprinting for file-edit tools and a command-prefix + stable-JSON strategy for others, to enable loop detection.",
      "tags": ["hashing", "utility", "tool-call"],
      "complexity": "moderate"
    },
    {
      "id": "function:scripts/hooks/ecc-metrics-bridge.js:readSessionCost",
      "type": "function",
      "name": "readSessionCost",
      "filePath": "scripts/hooks/ecc-metrics-bridge.js",
      "lineRange": [149, 202],
      "summary": "Reads a Claude session's cost JSONL transcript file, summing token counts and cost while detecting and warning about malformed or duplicate lines via a deduplication hash.",
      "tags": ["cost-tracking", "parsing", "file-io"],
      "complexity": "complex"
    },
    {
      "id": "function:scripts/hooks/ecc-metrics-bridge.js:run",
      "type": "function",
      "name": "run",
      "filePath": "scripts/hooks/ecc-metrics-bridge.js",
      "lineRange": [208, 270],
      "summary": "Main hook entry point that reads stdin JSON, updates the session bridge with current tool call metrics (cost, tokens, recent files, tool hash history), then atomically persists the result.",
      "tags": ["hook", "entry-point", "event-handler"],
      "complexity": "complex"
    },
    {
      "id": "file:scripts/hooks/ecc-statusline.js",
      "type": "file",
      "name": "ecc-statusline.js",
      "filePath": "scripts/hooks/ecc-statusline.js",
      "summary": "Hook that renders a terminal statusline displaying live session metrics (cost, tokens, duration, context bar, current task) by reading data from the session bridge and active agent TODO files.",
      "tags": ["hook", "ui", "monitoring", "event-handler"],
      "complexity": "moderate"
    },
    {
      "id": "function:scripts/hooks/ecc-statusline.js:runStatusline",
      "type": "function",
      "name": "runStatusline",
      "filePath": "scripts/hooks/ecc-statusline.js",
      "lineRange": [88, 164],
      "summary": "Main statusline renderer — reads stdin hook input, loads bridge data, optionally resets session origin, reads the current task, and writes a formatted terminal status string to stdout.",
      "tags": ["ui", "hook", "entry-point"],
      "complexity": "complex"
    },
    {
      "id": "file:scripts/lib/session-bridge.js",
      "type": "file",
      "name": "session-bridge.js",
      "filePath": "scripts/lib/session-bridge.js",
      "summary": "Low-level shared-state library providing atomic read/write operations on a per-session bridge JSON file in the OS temp directory, used by all ECC hooks to share metrics between invocations.",
      "tags": ["utility", "file-io", "session", "service"],
      "complexity": "moderate"
    },
    {
      "id": "function:scripts/lib/session-bridge.js:writeBridgeAtomic",
      "type": "function",
      "name": "writeBridgeAtomic",
      "filePath": "scripts/lib/session-bridge.js",
      "lineRange": [74, 84],
      "summary": "Atomically writes a data object to the session bridge file via a temp file + rename strategy to prevent partial reads by concurrent hook processes.",
      "tags": ["file-io", "atomic-write", "utility"],
      "complexity": "simple"
    },
    {
      "id": "function:scripts/lib/session-bridge.js:renameWithRetry",
      "type": "function",
      "name": "renameWithRetry",
      "filePath": "scripts/lib/session-bridge.js",
      "lineRange": [107, 129],
      "summary": "Retries a file rename on transient EBUSY/EPERM/EACCES errors with exponential backoff using Atomics.wait, tolerating the cross-process contention common on Windows.",
      "tags": ["file-io", "retry-logic", "utility"],
      "complexity": "moderate"
    },
    {
      "id": "function:scripts/lib/session-bridge.js:readBridge",
