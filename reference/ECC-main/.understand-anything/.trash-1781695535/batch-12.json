      "name": "cost-tracker.js",
      "filePath": "scripts/hooks/cost-tracker.js",
      "summary": "Claude Code hook that tracks API cost and token usage per session by reading harness cost files and parsing Claude session transcripts, then emitting cost-summary data for downstream consumers.",
      "tags": ["hook", "cost-tracking", "event-handler", "utility"],
      "complexity": "moderate"
    },
