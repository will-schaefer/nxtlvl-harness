      "type": "file",
      "name": "tmux-worktree-orchestrator.js",
      "filePath": "scripts/lib/tmux-worktree-orchestrator.js",
      "summary": "Core library implementing the tmux-based git worktree orchestration engine — builds orchestration plans, provisions worktree branches, seeds files, launches tmux sessions for parallel agent workers, and handles rollback on failure.",
      "tags": ["service", "utility", "orchestration", "entry-point"],
      "complexity": "complex",
      "languageNotes": "CommonJS module with injectable dependency seams (Impl-suffix parameters in executePlan) enabling fine-grained unit testing without spawning real processes."
    },
    {
      "id": "file:scripts/orchestrate-worktrees.js",
      "type": "file",
      "name": "orchestrate-worktrees.js",
      "filePath": "scripts/orchestrate-worktrees.js",
      "summary": "CLI entry point for the worktree orchestrator — parses arguments, loads a JSON plan config, and delegates to the library to dry-run, write-only materialize, or fully execute the orchestration plan via tmux.",
      "tags": ["entry-point", "utility", "orchestration"],
      "complexity": "moderate"
    },
    {
