{
  "name": "nxtlvl-workbench",
  "version": "0.0.0",
  "private": true,
  "description": "nxtlvl personal Claude Code harness — root dev tooling (typecheck + test) for the TypeScript migration.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test 'plugins/nxtlvl/**/*.test.ts' 'plugins/nxtlvl/**/*.test.js' 'scripts/multi-cli-compiler/*.test.ts'",
    "compile-multi-cli": "node scripts/multi-cli-compiler/compile.ts"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  },
  "engines": {
    "node": ">=24.12"
  }
}
