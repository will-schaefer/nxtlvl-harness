# Node dependencies — root dev tooling (typecheck + test)
node_modules/

# Secrets — loaded at runtime from 1Password; never commit raw keys
.envrc

# Local embeddings / Smart Connections index (large, machine-local)
.smart-env/

# macOS noise
.DS_Store
**/.DS_Store

# Nested editor-config repos with their own git history — keep out of this bundle
config/helix/

# Harness-review scratch — reactive clones only, always disposable (ADR-003 amendment
# 2026-07-11: vendored study copies retired). The durable record of a reviewed harness is
# its distillation in docs/reference/ plus its row in the nxtlvl-wiki repo manifest.
/reference/

# Packaged skill bundles — built artifacts; rebuild from source, don't track.
*.skill

# Claude Code local settings — the per-machine layer the tool auto-writes on every
# permission approval. Durable, portable config lives in .claude/settings.json (tracked).
.claude/settings.local.json

# Skill-creator eval workspaces — throwaway run artifacts (benchmarks, desc-opt), not source.
*-workspace/

# Scratch harness explorations — local-only pulls of external skill repos, not our source.
ai-engineering-from-scratch/

# Subagent-driven-development progress ledger — git-ignored scratch (recovery map, not source).
.superpowers/
llm-wiki/

# Local tool config with machine-specific absolute paths — not shared source.
.grok/

# Generated ADR dependency map — `node scripts/adr/graph.ts --html` opt-in artifact for
# manual review. Decision B keeps the default `adr graph` render in-session (--json, no
# repo file); the HTML viewer is regenerated on demand, never tracked.
docs/decisions/graph.html
