# Secrets — loaded at runtime from 1Password; never commit raw keys
.envrc

# Local embeddings / Smart Connections index (large, machine-local)
.smart-env/

# macOS noise
.DS_Store
**/.DS_Store

# Nested editor-config repos with their own git history — keep out of this bundle
config/helix/

# Vendored references — large, machine-local "books on the shelf".
# reference/ECC-main is vendored in-repo intentionally and IS tracked; everything else
# under reference/ (and any nested .DS_Store) stays local. Our own analysis lives in docs/reference/.
/reference/*
!/reference/ECC-main

# Packaged skill bundles — built artifacts; rebuild from source, don't track.
*.skill
