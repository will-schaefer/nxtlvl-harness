# ── Kitty Configuration ─────────────────────────
# Managed by GNU Stow (~/dotfiles/kitty/)

chdir ~/Developer

# ── Remote control (for kitty-theme live reload) ──
allow_remote_control yes
listen_on unix:/tmp/kitty-{kitty_pid}

# ── Theme (background, opacity, tab chrome) ─────
include current-theme.conf
# Helix frosted-light surfaces: match helix/themes/google-code-light.toml bg0-bg4
transparent_background_colors #F3F4F6@0.94 #FFFFFF@0.94 #F7F7F7@0.94 #EDEDED@0.94 #C7CCD1@0.94

# ── Font ────────────────────────────────────────
font_family FiraCodeNerdFontMono-Regular
bold_font auto
bold_is_bright yes
font_size 14

# ── Gemini CLI Color Theme ──────────────────────
foreground #E3E3E3
cursor #AF5CF7
cursor_text_color #131314
selection_background #4285F4
selection_foreground #E3E3E3

# ANSI Normal colors (0-7)
color0  #131314
color1  #EA4335
color2  #34A853
color3  #FBBC04
color4  #4285F4
color5  #AF5CF7
color6  #4FC3F7
color7  #C4C7C5

# ANSI Bright colors (8-15)
color8  #8E918F
color9  #FF6B5E
color10 #56D364
color11 #FFD54F
color12 #6EA8FE
color13 #C77DFF
color14 #7DD6FC
color15 #E3E3E3

# ── macOS ───────────────────────────────────────
macos_option_as_alt       yes
macos_titlebar_color      background
macos_quit_when_last_window_closed no

# ── Layouts & Shell ─────────────────────────────
enabled_layouts     tall,fat,grid,splits,stack
shell_integration   enabled
confirm_os_window_close 1

# ── Split borders ─────────────────────────────
active_border_color   #AF5CF7
inactive_border_color #45475a

# ── Tab bar ─────────────────────────────────────
tab_bar_edge top
tab_bar_style custom
powerline_style slanted
tab_bar_margin_width 8.0
tab_bar_min_tabs 2
active_tab_font_style bold
inactive_tab_font_style normal
tab_title_template "{title}/{tab.active_wd.rsplit('/', 1)[-1] or '/'}"

# ── Startup session ─────────────────────────────
startup_session sessions/dev.conf

# ── Tab shortcuts ───────────────────────────────
# Keyboard shortcuts
# Remove builtin mappings so custom shortcuts are deterministic.
clear_all_shortcuts yes

# Core macOS shortcuts to keep
map cmd+c copy_or_noop
map cmd+v paste_from_clipboard
map cmd+n new_os_window
map cmd+q quit

map cmd+1 goto_tab 1
map cmd+2 goto_tab 2
map cmd+3 goto_tab 3
map cmd+4 goto_tab 4
map cmd+5 goto_tab 5
map cmd+6 goto_tab 6
map cmd+7 goto_tab 7
map cmd+8 goto_tab 8
map cmd+9 goto_tab 9

# Mac-style tab workflow
map cmd+t new_tab
map cmd+shift+t launch --type=tab --cwd=current /bin/zsh /Users/willschaefer/dotfiles/kitty/.config/kitty/scripts/open-backlog-tui.zsh
map cmd+w close_tab
map cmd+shift+w close_window
map cmd+shift+] next_tab
map cmd+shift+[ previous_tab
map cmd+shift+} move_tab_forward
map cmd+shift+{ move_tab_backward

# ── Splits (replacing tmux) ────────────────────
map cmd+d           launch --cwd=current --location=vsplit
map cmd+shift+d     launch --cwd=current --location=hsplit
map cmd+]           next_window
map cmd+[           previous_window
map cmd+shift+enter toggle_layout stack

# Layout cycling
map ctrl+shift+l    next_layout

# Resize
map cmd+shift+left  resize_window narrower 2
map cmd+shift+right resize_window wider 2
map cmd+shift+up    resize_window taller 2
map cmd+shift+down  resize_window shorter 2

# ── Helix integration ──────────────────────────
map cmd+s send_text all \x1b:w\r
map cmd+shift+s send_text all \x1b:w\040

# ── Scrollback search ────────────────────────
map cmd+shift+r load_config_file
map cmd+0 set_tab_title
map cmd+f show_scrollback

# Dev workspace (fzf project picker → cd into project)
map cmd+p send_text all dev-workspace\r

# AI model tabs — each opens in a new full tab
map cmd+shift+c   launch --type=tab --cwd=current claude
map cmd+shift+g   launch --type=tab --cwd=current gemini
map cmd+shift+x   launch --type=tab --cwd=current codex
map cmd+shift+h   launch --type=background --allow-remote-control --cwd=current /bin/zsh /Users/willschaefer/dotfiles/kitty/.config/kitty/scripts/codex-helix-layout.zsh
map cmd+ctrl+h    launch --type=background --allow-remote-control --cwd=current /bin/zsh /Users/willschaefer/dotfiles/kitty/.config/kitty/scripts/codex-helix-layout.zsh

# Tool panes — 35% right split, replaces any existing tool pane
map cmd+b         kitten open_tool.py textual
map cmd+e         kitten open_tool.py hx
map cmd+g         kitten open_tool.py lazygit
map cmd+y         kitten open_tool.py yazi
map cmd+k         kitten open_tool.py taskell
map cmd+shift+k   kitten open_tool.py taskell
map cmd+shift+o   kitten open_tool.py dooit
map cmd+m         kitten open_tool.py glow
map cmd+shift+m   kitten open_tool.py glow

# Fallback mappings (macOS can reserve some cmd shortcuts in some contexts)
map cmd+ctrl+b    kitten open_tool.py textual
map cmd+ctrl+e    kitten open_tool.py hx
map cmd+ctrl+g    kitten open_tool.py lazygit
map cmd+ctrl+y    kitten open_tool.py yazi
map cmd+ctrl+k    kitten open_tool.py taskell
map cmd+ctrl+o    kitten open_tool.py dooit
map cmd+ctrl+m    kitten open_tool.py glow

# ── Seamless Helix ↔ Kitty split navigation ──
map ctrl+left  kitten helix_nav.py left  ctrl+left
map ctrl+right kitten helix_nav.py right ctrl+right
map ctrl+up    kitten helix_nav.py top   ctrl+up
map ctrl+down  kitten helix_nav.py bottom ctrl+down
